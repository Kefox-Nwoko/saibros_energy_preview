# Copy this file to .env and fill in your values

# SMTP settings for your mail host (cPanel / shared hosting)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true

# The email account used to send messages
SMTP_USER=inquiry@yourdomain.com
SMTP_PASS=your-email-password

# Where contact form submissions get delivered
RECIPIENT_EMAIL=info@saibrosgroup.com

# Port for the local service to run on
PORT=3001

# Allowed origins (comma-separated). Use * for any, or your domain(s)
ALLOWED_ORIGINS=https://www.saibrosgroup.com,http://localhost:5500
